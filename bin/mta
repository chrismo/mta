#!/usr/bin/env bash
# mta - Human-friendly launcher for MTA contexts
#
# Usage:
#   mta                    Interactive grdy+fzf picker → claude /mta:join
#   mta <ticket>           Create-if-missing → claude /mta:join <ticket>
#   mta <ticket> <wd>      Create-if-missing → claude-slot <wd> /mta:join <ticket>
#
# Environment:
#   MTA_DRY_RUN=1          Print the command instead of executing (for testing)
#   MTA_FZF_CMD            Override fzf command (for testing, e.g. "fzf --filter=X")

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ENGINE="${SCRIPT_DIR}/mta-engine"

# Create context if it doesn't exist yet
ensure_context() {
  local ticket="$1"
  if "$ENGINE" get-context "$ticket" &>/dev/null; then
    return
  fi
  "$ENGINE" create-context "$ticket" "$ticket"
}

# Execute or dry-run a command
run_or_print() {
  if [[ "${MTA_DRY_RUN:-}" == "1" ]]; then
    echo "$*"
  else
    exec "$@"
  fi
}

case "${1:-}" in
  help|--help|-h)
    cat <<HELP
mta - Launch Claude sessions on MTA contexts

Usage:
  mta                    Interactive picker (grdy+fzf) → claude /mta:join
  mta <ticket>           Create context if needed → claude /mta:join <ticket>
  mta <ticket> <wd>      Create context if needed → claude-slot <wd> /mta:join <ticket>

For engine commands (journal, set-priority, status, etc.):
  mta-engine help
HELP
    exit 0
    ;;
esac

if [[ $# -gt 2 ]]; then
  echo "Usage: mta [<ticket> [<working-dir>]]" >&2
  exit 1
fi

if [[ $# -eq 0 ]]; then
  # Interactive mode: list contexts → grdy (table) → fzf (pick) → join
  json_output=$("$ENGINE" list-contexts --format=json)

  if [[ -z "$json_output" || "$json_output" == "No contexts found." ]]; then
    echo "No contexts found. Create one with: mta <ticket>" >&2
    exit 1
  fi

  for cmd in grdy fzf; do
    if ! command -v "$cmd" &>/dev/null; then
      echo "$cmd not found. Install it or pass a ticket directly: mta <ticket>" >&2
      exit 1
    fi
  done

  # grdy renders JSON as a nice table, fzf picks a row, then extract ticket
  table=$(echo "$json_output" | grdy)
  # Header is 3 lines (top border, column names, separator), footer is 1 line (bottom border)
  # Feed data rows to fzf, show the column header as fzf header
  header=$(echo "$table" | head -n 3)
  if [[ -n "${MTA_FZF_CMD:-}" ]]; then
    pick=$(echo "$table" | tail -n +4 | sed '$d' | $MTA_FZF_CMD)
  else
    pick=$(echo "$table" | tail -n +4 | sed '$d' | fzf --header="$header" --prompt="Pick context: ")
  fi
  # Extract ticket from first column: │ TICKET │ ... │
  ticket=$(echo "$pick" | awk -F'│' '{gsub(/^[[:space:]]+|[[:space:]]+$/, "", $2); print $2}')
  run_or_print claude "/mta:join ${ticket}"
else
  ticket="$1"
  ensure_context "$ticket"

  if [[ $# -eq 2 ]]; then
    wd="$2"
    run_or_print claude-slot "$wd" "/mta:join ${ticket}"
  else
    run_or_print claude "/mta:join ${ticket}"
  fi
fi
