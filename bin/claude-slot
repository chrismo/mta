#!/bin/bash
#
# claude-slot - Open a new Ghostty tab, cd to a worktree, and start Claude
#
# Usage: claude-slot <worktree> [prompt]
#        claude-slot ds5
#        claude-slot ds5 /mta:join PROJ-123
#        claude-slot ds8 /yah
#
# Based on: https://github.com/zeitlings/alfred-ghostty-script
#

set -euo pipefail

usage() {
    echo "Usage: claude-slot <worktree> [prompt]"
    echo "Examples:"
    echo "  claude-slot ds5"
    echo "  claude-slot ds5 /mta:join PROJ-123"
    echo "  claude-slot ds8 /yah"
}

if [[ "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
    usage
    exit 0
fi

worktree="${1:-}"
shift || true
prompt="${*:-}"

if [[ -z "$worktree" ]]; then
    usage
    exit 1
fi

# Resolve worktree path
if [[ -d "$HOME/dev/$worktree" ]]; then
    wt_path="$HOME/dev/$worktree"
elif [[ -d "$worktree" ]]; then
    wt_path="$worktree"
else
    echo "Worktree not found: $worktree"
    echo "Tried: ~/dev/$worktree and $worktree"
    exit 1
fi

# The command to run in the new tab
# Set terminal title after cd to override any stale title from shell init
wt_name=$(basename "$wt_path")
if [[ -n "$prompt" ]]; then
    cmd="cd $wt_path && printf '\\033]0;%s\\007' '$wt_name' && claude \"$prompt\""
else
    cmd="cd $wt_path && printf '\\033]0;%s\\007' '$wt_name' && claude"
fi

# Write command to file before AppleScript (avoids quoting issues with colons)
mkdir -p /tmp/claude-slot
printf '%s' "$cmd" > /tmp/claude-slot/cmd.txt

osascript <<'EOF'
-- Adapted from AlfredGhostty Script
-- https://github.com/zeitlings/alfred-ghostty-script

on isRunning()
    application "Ghostty" is running
end isRunning

on hasWindows()
    if not isRunning() then return false
    tell application "System Events"
        return exists window 1 of process "Ghostty"
    end tell
end hasWindows

on waitForWindow(timeout_s)
    set end_time to (current date) + timeout_s
    repeat until hasWindows() or ((current date) > end_time)
        delay 0.05
    end repeat
    return hasWindows()
end waitForWindow

set just_activated to not isRunning()

tell application "Ghostty" to activate

if just_activated then
    if not waitForWindow(3) then
        display dialog "Failed to create initial window"
        return
    end if
    delay 0.5 -- Wait for shell to load
else
    delay 0.2
    -- Open new tab
    tell application "System Events"
        keystroke "t" using command down
    end tell
    delay 0.5 -- Wait for new tab shell to load
end if

-- Copy command from file to clipboard
do shell script "cat /tmp/claude-slot/cmd.txt | pbcopy"
delay 0.1

tell application "System Events"
    tell process "Ghostty"
        keystroke "v" using command down
        delay 0.1
        keystroke return
    end tell
end tell

EOF

if [[ -n "$prompt" ]]; then
    echo "Launched Claude in $worktree with: $prompt"
else
    echo "Launched Claude in $worktree"
fi
